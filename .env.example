# Walmart Marketplace REST API base URL.
# Most sellers use the default production endpoint below. Use your sandbox
# URL during testing.
WALMART_API_URL=https://marketplace.walmartapis.com/

# Walmart consumer ID (UUID). Issued by Walmart Marketplace when you
# register an integration in Seller Center.
WALMART_CONSUMER_ID=replace-me-with-a-uuid

# RSA private key (PEM, PKCS#8). Multi-line PEM bodies can be templated
# with literal `\n` escapes — the server unescapes them at startup.
# Use a read-only / minimum-privilege key where possible — v0.1 only
# exposes read endpoints, but defense in depth still applies.
WALMART_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEv...replace...me...\n-----END PRIVATE KEY-----

# Optional: Walmart channel-type GUID, attached as WM_CONSUMER.CHANNEL.TYPE.
# Some integration profiles require this; most do not.
WALMART_CHANNEL_TYPE=

# Optional: default seller ID. Currently informational — v0.1 does not
# attach it to outbound requests, but it surfaces in logs / debug output.
WALMART_DEFAULT_SELLER_ID=

# Optional: HTTP request timeout in seconds. Default 60.
WALMART_HTTP_TIMEOUT=60

# Optional: number of retry attempts on transient errors (5xx, 520, timeout). Default 3.
WALMART_MAX_RETRIES=3
